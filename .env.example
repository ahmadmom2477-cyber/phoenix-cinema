# ─────────────────────────────────────────────────────────────────────────────
# Phoenix Cinema — Environment Variables
# Copy this file to .env for local development.
# NEVER commit a real .env file to version control.
# In production (Render), set all variables via the Render dashboard.
# ─────────────────────────────────────────────────────────────────────────────

# ── Runtime ───────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=8080

# ── Admin authentication ──────────────────────────────────────────────────────
# Primary admin password (PHOENIX_* takes precedence over legacy ENAWI_*)
PHOENIX_ADMIN_PASS=change-me-strong-password-here

# ── Subscription HMAC secret ──────────────────────────────────────────────────
# Used to generate monthly subscription codes — keep this truly random and secret.
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
PHOENIX_SUB_SECRET=change-me-64-hex-chars-here

# ── Payment URL ───────────────────────────────────────────────────────────────
# Link shown to users for paying (WhatsApp, payment gateway, etc.)
PHOENIX_PAYMENT_URL=https://example.com/pay

# ── CORS / Frontend URL ───────────────────────────────────────────────────────
# In production, set this to the full URL of the deployed frontend.
# Leave blank in development (all origins allowed).
PHOENIX_FRONTEND_URL=https://your-app.onrender.com

# ── Feature flags ─────────────────────────────────────────────────────────────
# Downloads (torrent/magnet links) are DISABLED by default.
# Set to "true" only if you have the legal right to distribute the content.
ENABLE_DOWNLOADS=false

# ─────────────────────────────────────────────────────────────────────────────
# LEGACY VARIABLES (still supported as fallback — migrate to PHOENIX_* above)
# ─────────────────────────────────────────────────────────────────────────────
# ENAWI_ADMIN_PASS=
# ENAWI_SUB_SECRET=
# ENAWI_PAYMENT_URL=
# FRONTEND_URL=
